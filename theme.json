{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": false,
      "palette": [
        {
          "name": "Ink",
          "slug": "ink",
          "color": "#171b22"
        },
        {
          "name": "Brand",
          "slug": "brand",
          "color": "#17636f"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#d19435"
        },
        {
          "name": "Surface",
          "slug": "surface",
          "color": "#ffffff"
        }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Arial, 'Noto Sans Hebrew', 'Rubik', sans-serif",
          "name": "Hebrew Sans",
          "slug": "hebrew-sans"
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var:preset|font-family|hebrew-sans",
      "lineHeight": "1.65"
    },
    "color": {
      "background": "#f6f7f3",
      "text": "#171b22"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/trip-package-v1.json",
  "title": "Tra-Vel total-trip package contract",
  "type": "object",
  "required": ["contract_version", "data_mode", "currency", "provider_status", "origin", "destination", "insurance_catalog", "packages"],
  "properties": {
    "contract_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "data_mode": { "enum": ["demo", "live", "mixed"] },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "provider_status": { "type": "object", "required": ["connected", "adapter", "readiness", "bookable", "components"] },
    "origin": { "type": "object", "required": ["code", "city", "airport", "latitude", "longitude", "position"] },
    "destination": { "type": "object", "required": ["id", "code", "city", "country", "airport", "latitude", "longitude", "position"] },
    "insurance_catalog": { "type": "object", "required": ["none", "essential", "assisted", "extended"] },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "badge", "base_score", "flight", "stay", "default_insurance_tier", "transfer", "traits", "pros", "cons", "booking"]
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tra-vel.co.il/schemas/guide-source-packet.schema.json",
  "title": "Tra-Vel destination guide source packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "locale", "title", "excerpt", "primaryTopic", "canonicalPath", "status", "wordTargetMin", "checkedAt", "mapState", "sections", "sources", "facts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "locale": { "const": "he-IL" },
    "title": { "type": "string", "minLength": 2 },
    "excerpt": { "type": "string", "minLength": 50 },
    "primaryTopic": { "type": "string", "minLength": 3 },
    "canonicalPath": { "type": "string", "pattern": "^/[a-z0-9-]+/$" },
    "status": { "enum": ["research", "source-ready", "editorial-review", "publish-ready"] },
    "wordTargetMin": { "type": "integer", "minimum": 5000 },
    "checkedAt": { "type": "string", "format": "date" },
    "mapState": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "reviewer": { "type": "string" },
    "reviewMethod": { "type": "string", "minLength": 30 },
    "contentPath": { "type": "string", "pattern": "^content/guides/[a-z0-9-]+\\.(md|html)$" },
    "sections": {
      "type": "array",
      "minItems": 12,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "sources": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "publisher", "url", "type", "checkedAt", "supports"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string", "minLength": 3 },
          "publisher": { "type": "string", "minLength": 2 },
          "url": { "type": "string", "pattern": "^https://" },
          "type": { "enum": ["official", "primary", "industry", "editorial"] },
          "checkedAt": { "type": "string", "format": "date" },
          "supports": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "facts": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim", "sourceIds", "volatile"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "claim": { "type": "string", "minLength": 10 },
          "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "volatile": { "type": "boolean" },
          "recheckBeforePublish": { "type": "boolean" }
        }
      }
    }
  }
}

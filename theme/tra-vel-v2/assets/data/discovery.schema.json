{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/discovery-v1.json",
  "title": "Tra-Vel discovery contract",
  "type": "object",
  "required": ["contract_version", "data_mode", "currency", "origin", "provider_status", "destinations", "route_sets"],
  "properties": {
    "contract_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "data_mode": { "enum": ["demo", "live", "mixed"] },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "origin": {
      "type": "object",
      "required": ["code", "name", "city", "country", "latitude", "longitude"]
    },
    "provider_status": { "type": "object" },
    "destinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "city", "country", "position", "airport", "deal", "hotel", "weather", "tags", "image"]
      }
    },
    "route_sets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "label", "badge", "duration_minutes", "stops", "ticket_mode", "risk", "emissions_kg", "score", "costs", "pros", "cons"]
        }
      }
    }
  }
}

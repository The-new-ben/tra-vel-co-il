{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/insurance-quote-v1.json",
  "title": "Tra-Vel insurance quote contract",
  "type": "object",
  "required": ["contract_version", "data_mode", "currency", "provider_status", "destination", "risk_contexts", "plans"],
  "properties": {
    "contract_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "data_mode": { "enum": ["demo", "live", "mixed"] },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "provider_status": { "type": "object", "required": ["connected", "adapter", "readiness", "purchasable"] },
    "destination": { "type": "object", "required": ["id", "name", "medical_cost_context", "policy_note"] },
    "risk_contexts": { "type": "array", "minItems": 1 },
    "plans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "badge", "base_score", "service_score", "daily_base", "coverage", "service", "addon_rates", "underwriting", "exclusions", "pros", "cons", "purchase"]
      }
    }
  }
}

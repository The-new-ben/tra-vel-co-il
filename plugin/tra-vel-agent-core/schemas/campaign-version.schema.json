{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/campaign-version-v1.schema.json",
  "title": "Tra-Vel immutable benefit campaign version",
  "description": "A source-bound campaign evidence version. Numeric rates and fees belong in reviewed rules, never in an evergreen product identity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "campaign_id",
    "version",
    "provider_id",
    "program_ids",
    "credential_product_ids",
    "benefit_types",
    "windows",
    "inventory_cap_state",
    "ruleset_digest",
    "review_state",
    "status",
    "supersedes_version",
    "integration_state",
    "source",
    "commercial_truth"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "campaign_id": { "type": "string", "pattern": "^campaign_[a-z0-9][a-z0-9_]{2,53}$", "maxLength": 64 },
    "version": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "provider_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64 },
    "program_ids": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^program_[a-z0-9][a-z0-9_]{2,55}$", "maxLength": 64 }
    },
    "credential_product_ids": {
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^credential_[a-z0-9][a-z0-9_]{2,51}$", "maxLength": 64 }
    },
    "benefit_types": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "uniqueItems": true,
      "items": { "enum": ["points_redemption", "cash_plus_points", "card_linked_discount", "cashback_future", "conversion", "earn_for_later", "activation_offer"] }
    },
    "windows": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effective", "enrollment", "booking", "travel"],
      "properties": {
        "effective": { "$ref": "#/definitions/window" },
        "enrollment": { "$ref": "#/definitions/window" },
        "booking": { "$ref": "#/definitions/window" },
        "travel": { "$ref": "#/definitions/window" }
      }
    },
    "inventory_cap_state": { "enum": ["not_stated", "unknown", "available", "exhausted"] },
    "ruleset_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "review_state": { "enum": ["draft", "reviewed", "quarantined", "superseded"] },
    "status": { "enum": ["draft", "scheduled", "active", "expired", "suspended", "announced_not_operational"] },
    "supersedes_version": { "type": ["integer", "null"], "minimum": 1, "maximum": 2147483647 },
    "integration_state": { "$ref": "#/definitions/integration_state" },
    "source": { "$ref": "#/definitions/source" },
    "commercial_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_quote_available", "checkout_application_available"],
      "properties": {
        "provider_quote_available": { "const": false },
        "checkout_application_available": { "const": false }
      }
    }
  },
  "definitions": {
    "integration_state": {
      "enum": ["not_configured", "source_catalogued", "manual_planning_only", "announced_not_operational", "provider_authorization_required"]
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_utc", "to_utc"],
      "properties": {
        "from_utc": { "type": ["string", "null"], "format": "date-time" },
        "to_utc": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "official_source_url", "source_content_digest", "observed_at_utc", "fresh_until_utc", "locale", "review_state"],
      "properties": {
        "authority": { "enum": ["signed_partner_api", "provider_authorized_api", "official_rules", "official_product_page", "provider_support_confirmation", "customer_evidence", "customer_assertion"] },
        "official_source_url": { "type": ["string", "null"], "pattern": "^https://", "maxLength": 2048 },
        "source_content_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "observed_at_utc": { "type": "string", "format": "date-time" },
        "fresh_until_utc": { "type": "string", "format": "date-time" },
        "locale": { "type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$" },
        "review_state": { "enum": ["unreviewed", "reviewed", "quarantined", "superseded"] }
      }
    }
  }
}

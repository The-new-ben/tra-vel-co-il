{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/commerce-provider-v1.schema.json",
  "title": "Tra-Vel commerce sandbox provider descriptor",
  "description": "A safe server-registered descriptor. It contains no credential or raw supplier reference.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "provider_id",
    "display_name",
    "adapter_version",
    "environment",
    "relationship",
    "verticals",
    "capabilities",
    "priority",
    "readiness",
    "commercial_truth",
    "allowed_hosts",
    "jurisdictions",
    "licence",
    "settlement"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "provider_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$",
      "minLength": 3,
      "maxLength": 64
    },
    "display_name": { "type": "string", "minLength": 3, "maxLength": 80 },
    "adapter_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$",
      "maxLength": 40
    },
    "environment": { "const": "sandbox" },
    "relationship": { "enum": ["owned", "direct", "affiliate"] },
    "verticals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 9,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/vertical" }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "search",
          "revalidate",
          "reserve",
          "confirm",
          "fulfill",
          "change",
          "cancel",
          "refund",
          "payment_authorize",
          "payment_capture",
          "payment_void",
          "payment_refund",
          "webhook",
          "reconcile",
          "report_conversion",
          "settlement_reconcile"
        ]
      }
    },
    "priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["configuration", "status"],
      "properties": {
        "configuration": { "enum": ["seeded", "configured", "missing_credentials", "disabled"] },
        "status": { "enum": ["ready", "degraded", "offline"] }
      }
    },
    "commercial_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["simulated", "real_charge", "real_booking"],
      "properties": {
        "simulated": { "const": true },
        "real_charge": { "const": false },
        "real_booking": { "const": false }
      }
    },
    "allowed_hosts": {
      "type": "array",
      "maxItems": 0,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?=.{1,253}$)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z]{2,63}$"
      }
    },
    "jurisdictions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(?:[A-Z]{2}|global)$" }
    },
    "licence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reference_digest"],
      "properties": {
        "status": { "enum": ["sandbox_only", "not_required", "verified", "not_configured"] },
        "reference_digest": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "commission_bps", "currency", "payout_lag_days"],
      "properties": {
        "model": { "enum": ["owned", "commission", "affiliate", "net_rate"] },
        "commission_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "payout_lag_days": { "type": "integer", "minimum": 0, "maximum": 365 }
      }
    }
  },
  "definitions": {
    "vertical": {
      "enum": [
        "flight",
        "accommodation",
        "package",
        "transfer",
        "activity",
        "dining",
        "insurance",
        "connectivity",
        "equipment"
      ]
    }
  }
}

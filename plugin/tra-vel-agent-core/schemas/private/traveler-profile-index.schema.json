{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/private/traveler-profile-index.schema.json",
  "title": "Tra-Vel private traveler-profile evidence index",
  "description": "A closed, immutable-revision, vault-pointer-only index for progressive traveler registration. It stores evidence identities and readiness metadata, never raw identity, contact, document, health, authority, or loyalty values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "profile_ref",
    "account_ref",
    "traveler_ref",
    "subject_kind",
    "version",
    "previous_profile_digest",
    "profile_digest",
    "fields",
    "created_at",
    "updated_at",
    "data_boundary"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "profile_ref": { "$ref": "#/definitions/profileRef" },
    "account_ref": { "$ref": "#/definitions/accountRef" },
    "traveler_ref": { "$ref": "#/definitions/travelerRef" },
    "subject_kind": { "enum": ["adult", "minor", "dependent_adult"] },
    "version": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "previous_profile_digest": { "$ref": "#/definitions/nullableDigest" },
    "profile_digest": { "$ref": "#/definitions/digest" },
    "fields": {
      "type": "array",
      "maxItems": 96,
      "items": { "$ref": "#/definitions/profileField" }
    },
    "created_at": { "$ref": "#/definitions/dateTime" },
    "updated_at": { "$ref": "#/definitions/dateTime" },
    "data_boundary": { "$ref": "#/definitions/profileBoundary" }
  },
  "definitions": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nullableDigest": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "dateTime": { "type": "string", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "nullableDateTime": { "type": ["string", "null"], "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "profileRef": { "type": "string", "pattern": "^tv_profile_[A-Za-z0-9_-]{16,96}$" },
    "accountRef": { "type": "string", "pattern": "^tv_account_[A-Za-z0-9_-]{16,96}$" },
    "travelerRef": { "type": "string", "pattern": "^tv_traveler_[A-Za-z0-9_-]{16,96}$" },
    "fieldRef": { "type": "string", "pattern": "^tv_profile_field_[A-Za-z0-9_-]{16,96}$" },
    "nullableFieldRef": { "type": ["string", "null"], "pattern": "^tv_profile_field_[A-Za-z0-9_-]{16,96}$" },
    "vaultItemRef": { "type": "string", "pattern": "^tv_vault_item_[A-Za-z0-9_-]{16,96}$" },
    "fieldCode": {
      "enum": [
        "legal_name",
        "preferred_name",
        "date_of_birth",
        "passenger_type",
        "nationality",
        "residence_country",
        "sex_marker_if_supplier_required",
        "primary_email",
        "primary_mobile",
        "reachable_channel",
        "postal_address",
        "document_type",
        "document_number",
        "document_legal_name",
        "document_nationality",
        "document_issuing_country",
        "document_issued_at",
        "document_expires_at",
        "communication_language",
        "seat_preference",
        "meal_preference",
        "baggage_preference",
        "room_preference",
        "bed_preference",
        "dietary_requirement",
        "trip_pace",
        "wheelchair_assistance_level",
        "mobility_aid_specification",
        "battery_specification",
        "transfer_assistance",
        "hearing_assistance",
        "visual_assistance",
        "cognitive_assistance",
        "sensory_support",
        "service_animal",
        "medical_equipment",
        "medication_refrigeration",
        "accessible_room_requirement",
        "insurance_declaration_packet",
        "medical_clearance",
        "allergy_safety_packet",
        "guardian_relationship",
        "guardian_authority_packet",
        "dependent_support_plan",
        "companion_consent",
        "loyalty_program_membership",
        "loyalty_member_identifier",
        "loyalty_tier",
        "card_product_identity",
        "emergency_contact",
        "emergency_contact_authority"
      ]
    },
    "profileField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_ref",
        "field_code",
        "data_class",
        "value_digest",
        "vault_locator_ref",
        "source",
        "assurance",
        "state",
        "purposes",
        "retention_class",
        "observed_at",
        "valid_until",
        "source_evidence_digest",
        "supersedes_field_ref",
        "data_boundary"
      ],
      "properties": {
        "field_ref": { "$ref": "#/definitions/fieldRef" },
        "field_code": { "$ref": "#/definitions/fieldCode" },
        "data_class": { "enum": ["identity", "contact", "travel_document", "preference", "accessibility", "health", "authority", "loyalty", "emergency"] },
        "value_digest": { "$ref": "#/definitions/digest" },
        "vault_locator_ref": { "$ref": "#/definitions/vaultItemRef" },
        "source": { "enum": ["traveler", "document_capture", "operator", "supplier", "government_rules_provider", "imported_booking", "loyalty_provider"] },
        "assurance": { "enum": ["unverified", "self_asserted", "contact_verified", "document_matched", "authority_verified", "supplier_accepted"] },
        "state": { "enum": ["current", "expiring", "expired", "conflicted", "revoked"] },
        "purposes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "enum": ["planning", "quote", "reservation", "fulfillment", "travel_readiness", "servicing", "claim", "benefit_comparison"] }
        },
        "retention_class": { "enum": ["account_identity", "active_trip_contact", "travel_document", "preference", "accessibility_support", "restricted_health", "authority_evidence", "benefit_membership", "emergency_support"] },
        "observed_at": { "$ref": "#/definitions/dateTime" },
        "valid_until": { "$ref": "#/definitions/nullableDateTime" },
        "source_evidence_digest": { "$ref": "#/definitions/digest" },
        "supersedes_field_ref": { "$ref": "#/definitions/nullableFieldRef" },
        "data_boundary": { "$ref": "#/definitions/fieldBoundary" }
      }
    },
    "profileBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_only", "public_serialization_allowed", "vault_pointers_only", "raw_identity_data_stored", "raw_contact_data_stored", "raw_document_data_stored", "raw_medical_data_stored", "raw_loyalty_credentials_stored"],
      "properties": {
        "server_only": { "const": true },
        "public_serialization_allowed": { "const": false },
        "vault_pointers_only": { "const": true },
        "raw_identity_data_stored": { "const": false },
        "raw_contact_data_stored": { "const": false },
        "raw_document_data_stored": { "const": false },
        "raw_medical_data_stored": { "const": false },
        "raw_loyalty_credentials_stored": { "const": false }
      }
    },
    "fieldBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_only", "raw_value_stored", "vault_pointer_only"],
      "properties": {
        "server_only": { "const": true },
        "raw_value_stored": { "const": false },
        "vault_pointer_only": { "const": true }
      }
    }
  }
}

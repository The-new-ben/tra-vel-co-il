{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/private/stored-value-voucher-ledger.schema.json",
  "title": "Tra-Vel private stored-value voucher ledger",
  "type": "object", "additionalProperties": false,
  "required": ["contract_version", "environment", "voucher_ref", "record_digest", "idempotency_digest", "account_scope_digest", "program_ref", "issuer_ref", "owner_reference_digest", "beneficiary_reference_digest", "presented_beneficiary_reference_digest", "currency", "minor_unit_exponent", "fx_basis", "value", "expiry", "restrictions", "consumption", "audit_lineage", "created_at", "boundary"],
  "properties": {
    "contract_version": { "const": "1.1.0" }, "environment": { "const": "simulation" },
    "voucher_ref": { "type": "string", "pattern": "^stored_value_voucher_[A-Za-z0-9][A-Za-z0-9_-]{15,95}$" }, "record_digest": { "$ref": "#/definitions/digest" }, "idempotency_digest": { "$ref": "#/definitions/digest" }, "account_scope_digest": { "$ref": "#/definitions/digest" },
    "program_ref": { "type": "string", "pattern": "^program_[A-Za-z0-9][A-Za-z0-9_-]{15,95}$" }, "issuer_ref": { "type": "string", "pattern": "^issuer_[A-Za-z0-9][A-Za-z0-9_-]{15,95}$" }, "owner_reference_digest": { "$ref": "#/definitions/digest" }, "beneficiary_reference_digest": { "$ref": "#/definitions/digest" }, "presented_beneficiary_reference_digest": { "$ref": "#/definitions/digest" }, "currency": { "$ref": "#/definitions/currency" }, "minor_unit_exponent": { "type": "integer", "minimum": 0, "maximum": 4 },
    "fx_basis": { "type": "object", "additionalProperties": false, "required": ["source_currency", "settlement_currency", "source_minor_unit_exponent", "settlement_minor_unit_exponent", "rate_numerator", "rate_denominator", "rounding_mode", "observed_at", "valid_until", "source_digest"], "properties": { "source_currency": { "$ref": "#/definitions/currency" }, "settlement_currency": { "$ref": "#/definitions/currency" }, "source_minor_unit_exponent": { "type": "integer", "minimum": 0, "maximum": 4 }, "settlement_minor_unit_exponent": { "type": "integer", "minimum": 0, "maximum": 4 }, "rate_numerator": { "$ref": "#/definitions/positiveValue" }, "rate_denominator": { "$ref": "#/definitions/positiveValue" }, "rounding_mode": { "const": "floor_minor_unit" }, "observed_at": { "$ref": "#/definitions/dateTime" }, "valid_until": { "$ref": "#/definitions/dateTime" }, "source_digest": { "$ref": "#/definitions/digest" } } },
    "value": { "type": "object", "additionalProperties": false, "required": ["face_value_minor", "consumed_before_minor", "available_before_minor", "requested_consumption_minor", "applied_consumption_minor", "remaining_after_minor"], "properties": { "face_value_minor": { "$ref": "#/definitions/value" }, "consumed_before_minor": { "$ref": "#/definitions/value" }, "available_before_minor": { "$ref": "#/definitions/value" }, "requested_consumption_minor": { "$ref": "#/definitions/value" }, "applied_consumption_minor": { "$ref": "#/definitions/value" }, "remaining_after_minor": { "$ref": "#/definitions/value" } } },
    "expiry": { "type": "object", "additionalProperties": false, "required": ["issued_at", "expires_at", "evaluated_at", "state"], "properties": { "issued_at": { "$ref": "#/definitions/dateTime" }, "expires_at": { "$ref": "#/definitions/dateTime" }, "evaluated_at": { "$ref": "#/definitions/dateTime" }, "state": { "enum": ["current", "expired"] } } },
    "restrictions": { "type": "object", "additionalProperties": false, "required": ["transferability", "beneficiary_match_required", "partial_consumption_allowed", "stacking_allowed", "permitted_verticals", "permitted_supplier_refs", "minimum_purchase_minor", "evidence_digest"], "properties": { "transferability": { "enum": ["non_transferable", "designated_beneficiary", "reassignable_before_use"] }, "beneficiary_match_required": { "type": "boolean" }, "partial_consumption_allowed": { "type": "boolean" }, "stacking_allowed": { "type": "boolean" }, "permitted_verticals": { "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": { "$ref": "#/definitions/identifier" } }, "permitted_supplier_refs": { "type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": { "$ref": "#/definitions/supplierRef" } }, "minimum_purchase_minor": { "$ref": "#/definitions/value" }, "evidence_digest": { "$ref": "#/definitions/digest" } } },
    "consumption": { "type": "object", "additionalProperties": false, "required": ["operation_ref", "purchase_ref", "vertical", "supplier_ref", "settlement_currency", "purchase_total_minor", "source_amount_minor", "settlement_amount_minor", "rounding_remainder_numerator", "state", "blocked_reason", "consumption_at", "evidence_digest"], "properties": { "operation_ref": { "$ref": "#/definitions/operationRef" }, "purchase_ref": { "type": "string", "pattern": "^purchase_[A-Za-z0-9][A-Za-z0-9_-]{15,95}$" }, "vertical": { "$ref": "#/definitions/identifier" }, "supplier_ref": { "$ref": "#/definitions/supplierRef" }, "settlement_currency": { "$ref": "#/definitions/currency" }, "purchase_total_minor": { "$ref": "#/definitions/value" }, "source_amount_minor": { "$ref": "#/definitions/value" }, "settlement_amount_minor": { "$ref": "#/definitions/value" }, "rounding_remainder_numerator": { "$ref": "#/definitions/value" }, "state": { "enum": ["planned", "blocked_expired", "blocked_beneficiary", "blocked_restriction"] }, "blocked_reason": { "anyOf": [{ "$ref": "#/definitions/identifier" }, { "type": "null" }] }, "consumption_at": { "anyOf": [{ "$ref": "#/definitions/dateTime" }, { "type": "null" }] }, "evidence_digest": { "$ref": "#/definitions/digest" } } },
    "audit_lineage": { "type": "object", "additionalProperties": false, "required": ["operation_ref", "sequence", "previous_operation_digest", "source_event_digests", "lineage_digest", "immutable"], "properties": { "operation_ref": { "$ref": "#/definitions/operationRef" }, "sequence": { "$ref": "#/definitions/positiveValue" }, "previous_operation_digest": { "anyOf": [{ "$ref": "#/definitions/digest" }, { "type": "null" }] }, "source_event_digests": { "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": { "$ref": "#/definitions/digest" } }, "lineage_digest": { "$ref": "#/definitions/digest" }, "immutable": { "const": true } } },
    "created_at": { "$ref": "#/definitions/dateTime" }, "boundary": { "$ref": "#/definitions/boundary" }
  },
  "definitions": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "identifier": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" }, "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }, "dateTime": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" }, "value": { "type": "integer", "minimum": 0, "maximum": 1000000000000 }, "positiveValue": { "type": "integer", "minimum": 1, "maximum": 1000000000000 }, "supplierRef": { "type": "string", "pattern": "^supplier_[A-Za-z0-9][A-Za-z0-9_-]{15,95}$" }, "operationRef": { "type": "string", "pattern": "^stored_value_operation_[A-Za-z0-9][A-Za-z0-9_-]{15,95}$" },
    "boundary": { "type": "object", "additionalProperties": false, "required": ["server_only", "public_serialization_allowed", "simulation_only", "execution_authorized", "account_merge_authorized", "accrual_credit_authorized", "redemption_authorized", "voucher_consumption_authorized", "refund_authorized", "supplier_dispatched", "provider_called", "processor_called", "ledger_mutated", "message_sent"], "properties": { "server_only": { "const": true }, "public_serialization_allowed": { "const": false }, "simulation_only": { "const": true }, "execution_authorized": { "const": false }, "account_merge_authorized": { "const": false }, "accrual_credit_authorized": { "const": false }, "redemption_authorized": { "const": false }, "voucher_consumption_authorized": { "const": false }, "refund_authorized": { "const": false }, "supplier_dispatched": { "const": false }, "provider_called": { "const": false }, "processor_called": { "const": false }, "ledger_mutated": { "const": false }, "message_sent": { "const": false } } }
  }
}

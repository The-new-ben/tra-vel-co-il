{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/private/trip-dependency-graph.schema.json",
  "title": "Tra-Vel private immutable trip dependency graph",
  "description": "Server-only digest-and-reference itinerary graph. It contains no raw traveler, payment, medical, supplier payload, credential, or supplier-action claim.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "environment", "graph_ref", "graph_version", "previous_graph_digest", "graph_digest", "trip_ref", "owner_scope_digest", "party_flags", "nodes", "edges", "traveler_constraints", "created_at", "updated_at", "private_boundary"],
  "properties": {
    "contract_version": {"const": "1.0.0"},
    "environment": {"const": "sandbox"},
    "graph_ref": {"$ref": "#/definitions/graphRef"},
    "graph_version": {"type": "integer", "minimum": 1, "maximum": 2147483647},
    "previous_graph_digest": {"$ref": "#/definitions/nullableDigest"},
    "graph_digest": {"$ref": "#/definitions/digest"},
    "trip_ref": {"$ref": "#/definitions/tripRef"},
    "owner_scope_digest": {"$ref": "#/definitions/digest"},
    "party_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minor_present", "dependent_adult_present", "accessibility_required"],
      "properties": {
        "minor_present": {"type": "boolean"},
        "dependent_adult_present": {"type": "boolean"},
        "accessibility_required": {"type": "boolean"}
      }
    },
    "nodes": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"$ref": "#/definitions/node"}},
    "edges": {"type": "array", "minItems": 0, "maxItems": 384, "items": {"$ref": "#/definitions/edge"}},
    "traveler_constraints": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/definitions/constraint"}},
    "created_at": {"$ref": "#/definitions/dateTime"},
    "updated_at": {"$ref": "#/definitions/dateTime"},
    "private_boundary": {"$ref": "#/definitions/privateBoundary"}
  },
  "definitions": {
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullableDigest": {"anyOf": [{"type": "null"}, {"$ref": "#/definitions/digest"}]},
    "dateTime": {"type": "string", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"},
    "graphRef": {"type": "string", "pattern": "^tv_graph_[A-Za-z0-9_-]{16,96}$"},
    "tripRef": {"type": "string", "pattern": "^tv_trip_[A-Za-z0-9_-]{16,96}$"},
    "nodeRef": {"type": "string", "pattern": "^tv_node_[A-Za-z0-9_-]{16,96}$"},
    "edgeRef": {"type": "string", "pattern": "^tv_edge_[A-Za-z0-9_-]{16,96}$"},
    "deadlineRef": {"type": "string", "pattern": "^tv_deadline_[A-Za-z0-9_-]{16,96}$"},
    "constraintRef": {"type": "string", "pattern": "^tv_constraint_[A-Za-z0-9_-]{16,96}$"},
    "subjectRef": {"type": "string", "pattern": "^tv_subject_[A-Za-z0-9_-]{16,96}$"},
    "orderItemRef": {"type": "string", "pattern": "^tv_order_item_[A-Za-z0-9_-]{16,96}$"},
    "vaultRef": {"type": "string", "pattern": "^vaultptr_[a-z0-9_]{16,120}$"},
    "providerId": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64},
    "vertical": {"enum": ["flight", "accommodation", "package", "transfer", "activity", "dining", "insurance", "connectivity", "equipment"]},
    "nodeKind": {"enum": ["transport_segment", "stay", "bundled_service", "ground_mobility", "reserved_experience", "reserved_meal", "coverage", "connectivity_plan", "equipment_service"]},
    "nodeState": {"enum": ["planned", "held", "confirmed", "fulfilled", "at_risk", "disrupted", "cancelled", "uncertain", "superseded", "closed_with_loss"]},
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_ref", "vertical", "kind", "state", "service_window", "geography", "supplier", "deadlines", "artifact_digests"],
      "properties": {
        "node_ref": {"$ref": "#/definitions/nodeRef"},
        "vertical": {"$ref": "#/definitions/vertical"},
        "kind": {"$ref": "#/definitions/nodeKind"},
        "state": {"$ref": "#/definitions/nodeState"},
        "service_window": {"$ref": "#/definitions/serviceWindow"},
        "geography": {"$ref": "#/definitions/geography"},
        "supplier": {"$ref": "#/definitions/supplierConfirmation"},
        "deadlines": {"type": "array", "maxItems": 16, "items": {"$ref": "#/definitions/deadline"}},
        "artifact_digests": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"$ref": "#/definitions/digest"}}
      }
    },
    "serviceWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["starts_at", "ends_at", "timezone"],
      "properties": {
        "starts_at": {"$ref": "#/definitions/dateTime"},
        "ends_at": {"$ref": "#/definitions/dateTime"},
        "timezone": {"type": "string", "minLength": 1, "maxLength": 64}
      }
    },
    "geography": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin_location_digest", "destination_location_digest", "country_code", "local_tourism"],
      "properties": {
        "origin_location_digest": {"$ref": "#/definitions/digest"},
        "destination_location_digest": {"$ref": "#/definitions/digest"},
        "country_code": {"type": "string", "pattern": "^[A-Z]{2}$"},
        "local_tourism": {"type": "boolean"}
      }
    },
    "supplierConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_id", "order_item_ref", "confirmation_state", "confirmation_digest", "observed_at", "valid_until"],
      "properties": {
        "provider_id": {"$ref": "#/definitions/providerId"},
        "order_item_ref": {"$ref": "#/definitions/orderItemRef"},
        "confirmation_state": {"enum": ["unverified", "pending", "verified_current", "stale", "rejected", "unavailable", "uncertain"]},
        "confirmation_digest": {"$ref": "#/definitions/nullableDigest"},
        "observed_at": {"anyOf": [{"type": "null"}, {"$ref": "#/definitions/dateTime"}]},
        "valid_until": {"anyOf": [{"type": "null"}, {"$ref": "#/definitions/dateTime"}]}
      }
    },
    "deadline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deadline_ref", "type", "due_at", "state", "evidence_digest"],
      "properties": {
        "deadline_ref": {"$ref": "#/definitions/deadlineRef"},
        "type": {"enum": ["ticketing_limit", "free_cancellation_cutoff", "change_cutoff", "checkin_open", "checkin_close", "boarding_close", "arrival_notification", "pickup_window", "activity_start", "claim_notice", "refund_follow_up", "dispute_response", "equipment_return", "connectivity_activation", "operator_sla"]},
        "due_at": {"$ref": "#/definitions/dateTime"},
        "state": {"enum": ["open", "satisfied", "missed", "superseded", "uncertain"]},
        "evidence_digest": {"$ref": "#/definitions/nullableDigest"}
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_ref", "from_node_ref", "to_node_ref", "type", "criticality", "min_buffer_minutes", "geographic_handoff", "constraint_codes", "active"],
      "properties": {
        "edge_ref": {"$ref": "#/definitions/edgeRef"},
        "from_node_ref": {"$ref": "#/definitions/nodeRef"},
        "to_node_ref": {"$ref": "#/definitions/nodeRef"},
        "type": {"enum": ["temporal_before", "temporal_buffer", "geographic_handoff", "arrival_enables", "departure_requires", "inventory_bundle", "traveler_presence", "document_required", "authority_required", "accessibility_required", "financial_required", "supplier_confirmation_required", "local_availability_required", "weather_window", "connectivity_required", "equipment_required", "insurance_coverage"]},
        "criticality": {"enum": ["advisory", "important", "trip_critical", "safety_critical"]},
        "min_buffer_minutes": {"type": "integer", "minimum": 0, "maximum": 10080},
        "geographic_handoff": {"anyOf": [{"type": "null"}, {"$ref": "#/definitions/geographicHandoff"}]},
        "constraint_codes": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$", "maxLength": 96}},
        "active": {"type": "boolean"}
      }
    },
    "geographicHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["departure_location_digest", "arrival_location_digest", "mode", "feasibility_state", "evidence_digest"],
      "properties": {
        "departure_location_digest": {"$ref": "#/definitions/digest"},
        "arrival_location_digest": {"$ref": "#/definitions/digest"},
        "mode": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$", "maxLength": 96},
        "feasibility_state": {"enum": ["verified", "at_risk", "unknown", "impossible"]},
        "evidence_digest": {"$ref": "#/definitions/nullableDigest"}
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constraint_ref", "subject_ref", "type", "required_node_refs", "state", "evidence_digest", "verified_at", "valid_until", "vault_pointer_ref"],
      "properties": {
        "constraint_ref": {"$ref": "#/definitions/constraintRef"},
        "subject_ref": {"$ref": "#/definitions/subjectRef"},
        "type": {"enum": ["traveler_manifest", "minor_guardian_authority", "dependent_adult_authority", "accessibility_match", "document_admissibility", "customer_consent_scope", "payment_authority", "refund_destination_authority", "restricted_health_evidence", "emergency_contact_route"]},
        "required_node_refs": {"type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": {"$ref": "#/definitions/nodeRef"}},
        "state": {"enum": ["verified_current", "required", "stale", "conflict", "missing", "not_applicable"]},
        "evidence_digest": {"$ref": "#/definitions/nullableDigest"},
        "verified_at": {"anyOf": [{"type": "null"}, {"$ref": "#/definitions/dateTime"}]},
        "valid_until": {"anyOf": [{"type": "null"}, {"$ref": "#/definitions/dateTime"}]},
        "vault_pointer_ref": {"anyOf": [{"type": "null"}, {"$ref": "#/definitions/vaultRef"}]}
      }
    },
    "privateBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_only", "public_serialization_allowed", "raw_identity_data_stored", "raw_payment_data_stored", "raw_medical_data_stored", "raw_supplier_payload_stored", "bearer_secret_stored", "vault_pointers_only", "supplier_action_claimed"],
      "properties": {
        "server_only": {"const": true},
        "public_serialization_allowed": {"const": false},
        "raw_identity_data_stored": {"const": false},
        "raw_payment_data_stored": {"const": false},
        "raw_medical_data_stored": {"const": false},
        "raw_supplier_payload_stored": {"const": false},
        "bearer_secret_stored": {"const": false},
        "vault_pointers_only": {"const": true},
        "supplier_action_claimed": {"const": false}
      }
    }
  }
}

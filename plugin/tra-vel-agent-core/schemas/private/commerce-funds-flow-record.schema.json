{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/private/commerce-funds-flow-record.schema.json",
  "title": "Tra-Vel server-only per-item funds-flow record",
  "description": "A closed, immutable-revision sandbox ledger binding one order item to its commercial model, funds parties, payment observations, liabilities, settlement and private routes. Public callers receive only a digest projection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "environment",
    "funds_flow_ref",
    "funds_flow_binding_digest",
    "version",
    "previous_snapshot_digest",
    "snapshot_digest",
    "owner_scope_digest",
    "order_ref",
    "order_version",
    "order_digest",
    "order_item_ref",
    "offer_digest",
    "routing_binding_digest",
    "provider_id",
    "vertical",
    "commercial_model",
    "currency",
    "minor_unit_exponent",
    "parties",
    "commercial_terms",
    "pricing",
    "payment",
    "settlement",
    "liabilities",
    "private_routes",
    "created_at",
    "updated_at",
    "last_event_sequence",
    "sandbox_truth",
    "data_boundary"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "environment": { "const": "sandbox" },
    "funds_flow_ref": { "$ref": "#/definitions/fundsFlowRef" },
    "funds_flow_binding_digest": { "$ref": "#/definitions/digest" },
    "version": { "$ref": "#/definitions/positiveVersion" },
    "previous_snapshot_digest": { "$ref": "#/definitions/nullableDigest" },
    "snapshot_digest": { "$ref": "#/definitions/digest" },
    "owner_scope_digest": { "$ref": "#/definitions/digest" },
    "order_ref": { "$ref": "#/definitions/orderRef" },
    "order_version": { "$ref": "#/definitions/positiveVersion" },
    "order_digest": { "$ref": "#/definitions/digest" },
    "order_item_ref": { "$ref": "#/definitions/orderItemRef" },
    "offer_digest": { "$ref": "#/definitions/digest" },
    "routing_binding_digest": { "$ref": "#/definitions/digest" },
    "provider_id": { "$ref": "#/definitions/providerId" },
    "vertical": { "$ref": "#/definitions/vertical" },
    "commercial_model": { "$ref": "#/definitions/commercialModel" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "minor_unit_exponent": { "type": "integer", "minimum": 0, "maximum": 4 },
    "parties": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "merchant_of_record",
        "payment_collector",
        "supplier_payee",
        "commission_payee",
        "refund_liability_party",
        "chargeback_liability_party",
        "tax_remitter"
      ],
      "properties": {
        "merchant_of_record": { "$ref": "#/definitions/fundsParty" },
        "payment_collector": { "$ref": "#/definitions/fundsParty" },
        "supplier_payee": { "enum": ["supplier", "affiliate_network", "internal"] },
        "commission_payee": { "enum": ["platform", "affiliate_network", "not_applicable"] },
        "refund_liability_party": { "$ref": "#/definitions/liabilityParty" },
        "chargeback_liability_party": { "$ref": "#/definitions/liabilityParty" },
        "tax_remitter": { "$ref": "#/definitions/liabilityParty" }
      }
    },
    "commercial_terms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rate_card_ref",
        "rate_card_revision_digest",
        "source_revision_digest",
        "supplier_config_revision_digest",
        "effective_at",
        "valid_until",
        "calculation_basis",
        "commission_bps",
        "markup_amount_minor",
        "tax_treatment",
        "evidence_digest"
      ],
      "properties": {
        "rate_card_ref": { "$ref": "#/definitions/rateCardRef" },
        "rate_card_revision_digest": { "$ref": "#/definitions/digest" },
        "source_revision_digest": { "$ref": "#/definitions/digest" },
        "supplier_config_revision_digest": { "$ref": "#/definitions/digest" },
        "effective_at": { "$ref": "#/definitions/dateTime" },
        "valid_until": { "$ref": "#/definitions/dateTime" },
        "calculation_basis": { "enum": ["affiliate_commission", "gross_less_commission", "supplier_net_plus_markup"] },
        "commission_bps": { "type": ["integer", "null"], "minimum": 1, "maximum": 10000 },
        "markup_amount_minor": { "$ref": "#/definitions/money" },
        "tax_treatment": { "enum": ["included", "excluded", "not_applicable"] },
        "evidence_digest": { "$ref": "#/definitions/digest" }
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "customer_total_minor",
        "tax_minor",
        "supplier_net_minor",
        "commissionable_minor",
        "commission_receivable_minor",
        "platform_markup_minor",
        "supplier_payable_minor",
        "platform_revenue_minor"
      ],
      "properties": {
        "customer_total_minor": { "$ref": "#/definitions/money" },
        "tax_minor": { "$ref": "#/definitions/money" },
        "supplier_net_minor": { "$ref": "#/definitions/money" },
        "commissionable_minor": { "$ref": "#/definitions/money" },
        "commission_receivable_minor": { "$ref": "#/definitions/money" },
        "platform_markup_minor": { "$ref": "#/definitions/money" },
        "supplier_payable_minor": { "$ref": "#/definitions/money" },
        "platform_revenue_minor": { "$ref": "#/definitions/money" }
      }
    },
    "payment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "authority",
        "authorized_amount_minor",
        "captured_amount_minor",
        "refunded_amount_minor",
        "disputed_amount_minor",
        "charged_back_amount_minor",
        "processor_payment_ref",
        "latest_event_digest",
        "updated_at"
      ],
      "properties": {
        "state": { "enum": ["not_started", "authorization_pending", "authorized", "capture_pending", "partially_captured", "captured", "partially_refunded", "refunded", "disputed", "charged_back", "payment_failed", "uncertain"] },
        "authority": { "enum": ["platform_processor", "supplier_reported"] },
        "authorized_amount_minor": { "$ref": "#/definitions/money" },
        "captured_amount_minor": { "$ref": "#/definitions/money" },
        "refunded_amount_minor": { "$ref": "#/definitions/money" },
        "disputed_amount_minor": { "$ref": "#/definitions/money" },
        "charged_back_amount_minor": { "$ref": "#/definitions/money" },
        "processor_payment_ref": { "$ref": "#/definitions/nullableProcessorPaymentRef" },
        "latest_event_digest": { "$ref": "#/definitions/nullableDigest" },
        "updated_at": { "$ref": "#/definitions/dateTime" }
      }
    },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "supplier_due_minor",
        "supplier_paid_minor",
        "commission_due_minor",
        "commission_received_minor",
        "chargeback_recovery_due_minor",
        "chargeback_recovered_minor",
        "latest_reconciliation_digest",
        "due_at",
        "updated_at"
      ],
      "properties": {
        "state": { "enum": ["not_started", "accrued", "partially_settled", "settled", "disputed"] },
        "supplier_due_minor": { "$ref": "#/definitions/money" },
        "supplier_paid_minor": { "$ref": "#/definitions/money" },
        "commission_due_minor": { "$ref": "#/definitions/money" },
        "commission_received_minor": { "$ref": "#/definitions/money" },
        "chargeback_recovery_due_minor": { "$ref": "#/definitions/money" },
        "chargeback_recovered_minor": { "$ref": "#/definitions/money" },
        "latest_reconciliation_digest": { "$ref": "#/definitions/nullableDigest" },
        "due_at": { "$ref": "#/definitions/nullableDateTime" },
        "updated_at": { "$ref": "#/definitions/dateTime" }
      }
    },
    "liabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "customer_refund_due_minor",
        "supplier_payable_outstanding_minor",
        "commission_receivable_outstanding_minor",
        "chargeback_liability_minor",
        "chargeback_liability_party"
      ],
      "properties": {
        "customer_refund_due_minor": { "$ref": "#/definitions/money" },
        "supplier_payable_outstanding_minor": { "$ref": "#/definitions/money" },
        "commission_receivable_outstanding_minor": { "$ref": "#/definitions/money" },
        "chargeback_liability_minor": { "$ref": "#/definitions/money" },
        "chargeback_liability_party": { "$ref": "#/definitions/liabilityParty" }
      }
    },
    "private_routes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "private_routing_record_ref",
        "payment_route_ref",
        "settlement_route_ref",
        "supplier_payable_route_ref"
      ],
      "properties": {
        "private_routing_record_ref": { "$ref": "#/definitions/privateRoutingRecordRef" },
        "payment_route_ref": { "$ref": "#/definitions/paymentRouteRef" },
        "settlement_route_ref": { "$ref": "#/definitions/settlementRouteRef" },
        "supplier_payable_route_ref": { "$ref": "#/definitions/nullableSupplierPayableRouteRef" }
      }
    },
    "created_at": { "$ref": "#/definitions/dateTime" },
    "updated_at": { "$ref": "#/definitions/dateTime" },
    "last_event_sequence": { "type": "integer", "minimum": 0, "maximum": 2147483646 },
    "sandbox_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["simulated", "real_processor_call", "real_customer_charge", "real_supplier_payment", "real_settlement"],
      "properties": {
        "simulated": { "const": true },
        "real_processor_call": { "const": false },
        "real_customer_charge": { "const": false },
        "real_supplier_payment": { "const": false },
        "real_settlement": { "const": false }
      }
    },
    "data_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_only", "public_serialization_allowed", "contains_private_locators", "raw_credentials_stored", "raw_payment_data_stored", "personal_data_stored"],
      "properties": {
        "server_only": { "const": true },
        "public_serialization_allowed": { "const": false },
        "contains_private_locators": { "const": true },
        "raw_credentials_stored": { "const": false },
        "raw_payment_data_stored": { "const": false },
        "personal_data_stored": { "const": false }
      }
    }
  },
  "definitions": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nullableDigest": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "dateTime": { "type": "string", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "nullableDateTime": { "type": ["string", "null"], "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "money": { "type": "integer", "minimum": 0, "maximum": 1000000000000 },
    "positiveVersion": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "fundsFlowRef": { "type": "string", "pattern": "^fflow_[A-Za-z0-9_-]{16,96}$", "maxLength": 102 },
    "orderRef": { "type": "string", "pattern": "^tv_order_[A-Za-z0-9_-]{16,96}$", "maxLength": 120 },
    "orderItemRef": { "type": "string", "pattern": "^tv_order_item_[A-Za-z0-9_-]{16,96}$", "maxLength": 125 },
    "providerId": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64 },
    "rateCardRef": { "type": "string", "pattern": "^ratecard_[a-z0-9][a-z0-9_-]{7,95}$" },
    "privateRoutingRecordRef": { "type": "string", "pattern": "^tvr_binding_[A-Za-z0-9_-]{16,96}$" },
    "paymentRouteRef": { "type": "string", "pattern": "^payroute_[a-z0-9][a-z0-9_-]{7,95}$" },
    "settlementRouteRef": { "type": "string", "pattern": "^setroute_[a-z0-9][a-z0-9_-]{7,95}$" },
    "nullableSupplierPayableRouteRef": { "type": ["string", "null"], "pattern": "^payout_[a-z0-9][a-z0-9_-]{7,95}$" },
    "nullableProcessorPaymentRef": { "type": ["string", "null"], "pattern": "^paytxn_[a-z0-9][a-z0-9_-]{7,95}$" },
    "vertical": { "enum": ["flight", "accommodation", "package", "transfer", "activity", "dining", "insurance", "connectivity", "equipment"] },
    "commercialModel": { "enum": ["affiliate_handoff", "direct_commission", "net_rate_markup"] },
    "fundsParty": { "enum": ["platform", "supplier", "affiliate_network"] },
    "liabilityParty": { "enum": ["platform", "supplier", "affiliate_network", "shared", "not_applicable"] }
  }
}

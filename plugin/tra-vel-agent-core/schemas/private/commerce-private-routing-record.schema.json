{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/private/commerce-private-routing-record.schema.json",
  "title": "Tra-Vel server-only commerce routing record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "environment",
    "routing_binding_ref",
    "routing_binding_digest",
    "owner_scope_digest",
    "order_ref",
    "order_digest",
    "order_version",
    "order_item_ref",
    "component_ref",
    "provider_id",
    "vertical",
    "provider_reference_digest",
    "offer_ref",
    "offer_version",
    "offer_digest",
    "catalog_binding",
    "supplier_binding",
    "capability_binding",
    "private_route",
    "validity",
    "created_at",
    "private_boundary"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "environment": { "const": "sandbox" },
    "routing_binding_ref": { "$ref": "#/definitions/routingBindingRef" },
    "routing_binding_digest": { "$ref": "#/definitions/digest" },
    "owner_scope_digest": { "$ref": "#/definitions/digest" },
    "order_ref": { "$ref": "#/definitions/orderRef" },
    "order_digest": { "$ref": "#/definitions/digest" },
    "order_version": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "order_item_ref": { "$ref": "#/definitions/orderItemRef" },
    "component_ref": { "$ref": "#/definitions/componentRef" },
    "provider_id": { "$ref": "#/definitions/providerId" },
    "vertical": { "$ref": "#/definitions/vertical" },
    "provider_reference_digest": { "$ref": "#/definitions/digest" },
    "offer_ref": { "$ref": "#/definitions/offerRef" },
    "offer_version": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "offer_digest": { "$ref": "#/definitions/digest" },
    "catalog_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog_digest", "private_product_ref", "private_product_digest", "service_valid_until"],
      "properties": {
        "catalog_digest": { "$ref": "#/definitions/digest" },
        "private_product_ref": { "type": "string", "pattern": "^px_[a-z0-9_]{8,90}$" },
        "private_product_digest": { "$ref": "#/definitions/digest" },
        "service_valid_until": { "$ref": "#/definitions/dateTime" }
      }
    },
    "supplier_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network_signature", "profile_revision_id", "profile_revision_number", "profile_content_digest", "adapter_version", "source_revisions"],
      "properties": {
        "network_signature": { "$ref": "#/definitions/digest" },
        "profile_revision_id": { "type": "string", "pattern": "^suprev_[a-z0-9]{12,64}$" },
        "profile_revision_number": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "profile_content_digest": { "$ref": "#/definitions/digest" },
        "adapter_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$", "maxLength": 64 },
        "source_revisions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["product_revision_digest", "rate_revision_digest", "availability_revision_digest", "terms_revision_digest"],
          "properties": {
            "product_revision_digest": { "$ref": "#/definitions/digest" },
            "rate_revision_digest": { "$ref": "#/definitions/digest" },
            "availability_revision_digest": { "$ref": "#/definitions/digest" },
            "terms_revision_digest": { "$ref": "#/definitions/digest" }
          }
        }
      }
    },
    "capability_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frozen_capabilities", "capability_digest"],
      "properties": {
        "frozen_capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/capability" }
        },
        "capability_digest": { "$ref": "#/definitions/digest" }
      }
    },
    "private_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credential_ref", "endpoint_route_ref", "endpoint_host", "endpoint_evidence_digest", "tls_required", "redirect_policy", "operation_route_refs"],
      "properties": {
        "credential_ref": { "type": "string", "pattern": "^credref_[a-z0-9_]{8,120}$" },
        "endpoint_route_ref": { "$ref": "#/definitions/endpointRouteRef" },
        "endpoint_host": { "type": "string", "pattern": "^[a-z0-9.-]{3,253}\\.invalid$", "maxLength": 253 },
        "endpoint_evidence_digest": { "$ref": "#/definitions/digest" },
        "tls_required": { "const": true },
        "redirect_policy": { "const": "deny" },
        "operation_route_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capability", "primary_route_ref", "after_hours_route_ref"],
            "properties": {
              "capability": { "$ref": "#/definitions/capability" },
              "primary_route_ref": { "$ref": "#/definitions/operationRouteRef" },
              "after_hours_route_ref": { "$ref": "#/definitions/operationRouteRef" }
            }
          }
        }
      }
    },
    "validity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offer_fresh_until", "order_expires_at", "supplier_terms_valid_until", "credential_expires_at", "service_valid_until", "valid_until"],
      "properties": {
        "offer_fresh_until": { "$ref": "#/definitions/dateTime" },
        "order_expires_at": { "$ref": "#/definitions/dateTime" },
        "supplier_terms_valid_until": { "$ref": "#/definitions/dateTime" },
        "credential_expires_at": { "$ref": "#/definitions/dateTime" },
        "service_valid_until": { "$ref": "#/definitions/dateTime" },
        "valid_until": { "$ref": "#/definitions/dateTime" }
      }
    },
    "created_at": { "$ref": "#/definitions/dateTime" },
    "private_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_only", "public_serialization_allowed", "raw_credentials_stored", "vault_pointers_only", "contains_private_provider_locator"],
      "properties": {
        "server_only": { "const": true },
        "public_serialization_allowed": { "const": false },
        "raw_credentials_stored": { "const": false },
        "vault_pointers_only": { "const": true },
        "contains_private_provider_locator": { "const": true }
      }
    }
  },
  "definitions": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "dateTime": { "type": "string", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "routingBindingRef": { "type": "string", "pattern": "^tvr_binding_[A-Za-z0-9_-]{16,96}$" },
    "endpointRouteRef": { "type": "string", "pattern": "^tvr_endpoint_[A-Za-z0-9_-]{16,96}$" },
    "orderRef": { "type": "string", "pattern": "^tv_order_[A-Za-z0-9_-]{16,96}$" },
    "orderItemRef": { "type": "string", "pattern": "^tv_order_item_[A-Za-z0-9_-]{16,96}$" },
    "componentRef": { "type": "string", "pattern": "^tv_component_[A-Za-z0-9_-]{16,96}$" },
    "offerRef": { "type": "string", "pattern": "^tv_offer_[A-Za-z0-9_-]{16,96}$" },
    "providerId": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64 },
    "operationRouteRef": { "type": "string", "pattern": "^route_[a-z0-9_]{8,160}$", "maxLength": 166 },
    "vertical": { "enum": ["flight", "accommodation", "package", "transfer", "activity", "dining", "insurance", "connectivity", "equipment"] },
    "capability": { "enum": ["search", "revalidate", "reserve", "confirm", "fulfill", "change", "cancel", "refund", "payment_authorize", "payment_capture", "payment_void", "payment_refund", "webhook", "reconcile", "report_conversion", "settlement_reconcile", "affiliate_handoff"] }
  }
}

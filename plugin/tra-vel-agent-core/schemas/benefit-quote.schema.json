{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/benefit-quote-v1.schema.json",
  "title": "Tra-Vel benefit planning quote",
  "description": "A short-lived, explainable planning comparison. This v1 contract cannot alter checkout or execute a redemption.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "benefit_quote_id",
    "base_offer_snapshot_id",
    "base_offer_digest",
    "program_id",
    "campaign_id",
    "campaign_version",
    "connection_id",
    "decision_state",
    "reason_codes",
    "next_action_code",
    "verified_input_digest",
    "cash_effect",
    "points_effects",
    "quoted_at_utc",
    "expires_at_utc",
    "provider_quote_reference_digest",
    "source",
    "commercial_truth"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "benefit_quote_id": { "type": "string", "pattern": "^benefit_quote_[a-z0-9][a-z0-9_]{2,47}$", "maxLength": 64 },
    "base_offer_snapshot_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$", "maxLength": 96 },
    "base_offer_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "program_id": { "type": "string", "pattern": "^program_[a-z0-9][a-z0-9_]{2,55}$", "maxLength": 64 },
    "campaign_id": { "type": "string", "pattern": "^campaign_[a-z0-9][a-z0-9_]{2,53}$", "maxLength": 64 },
    "campaign_version": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "connection_id": { "type": ["string", "null"], "pattern": "^connection_[a-z0-9][a-z0-9_]{2,51}$", "maxLength": 64 },
    "decision_state": { "enum": ["eligible_verified", "likely_customer_asserted", "unknown_requires_action", "ineligible_verified"] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64 }
    },
    "next_action_code": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64 },
    "verified_input_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "cash_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "immediate_discount_minor", "future_reward_minor", "fees_minor", "payable_now_minor", "payable_later_minor"],
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "immediate_discount_minor": { "type": "integer", "minimum": 0 },
        "future_reward_minor": { "type": "integer", "minimum": 0 },
        "fees_minor": { "type": "integer", "minimum": 0 },
        "payable_now_minor": { "type": "integer", "minimum": 0 },
        "payable_later_minor": { "type": "integer", "minimum": 0 }
      }
    },
    "points_effects": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unit_code", "debit_integer", "earn_later_integer"],
        "properties": {
          "unit_code": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,31}$", "maxLength": 32 },
          "debit_integer": { "type": "integer", "minimum": 0 },
          "earn_later_integer": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "quoted_at_utc": { "type": "string", "format": "date-time" },
    "expires_at_utc": { "type": "string", "format": "date-time" },
    "provider_quote_reference_digest": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaign_source_digest", "base_offer_revalidated_at_utc", "observed_at_utc", "fresh_until_utc", "assurance"],
      "properties": {
        "campaign_source_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "base_offer_revalidated_at_utc": { "type": "string", "format": "date-time" },
        "observed_at_utc": { "type": "string", "format": "date-time" },
        "fresh_until_utc": { "type": "string", "format": "date-time" },
        "assurance": { "enum": ["provider_verified", "authorized_partner_verified", "official_terms_verified", "customer_evidence", "customer_asserted", "unknown"] }
      }
    },
    "commercial_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planning_only", "may_change_payable_total", "redemption_available"],
      "properties": {
        "planning_only": { "const": true },
        "may_change_payable_total": { "const": false },
        "redemption_available": { "const": false }
      }
    }
  }
}

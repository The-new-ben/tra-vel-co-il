{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/agent/trip-request-1.0.0.json",
  "title": "Tra-Vel TripRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "request_id", "revision", "summary", "language", "origin_text", "destination_mode", "destinations", "date_text", "date_flexibility", "travelers", "budget", "vibes", "hard_constraints", "preferences", "search_scope", "material_questions", "assumptions", "confidence", "source", "readiness"],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "request_id": { "type": "string", "format": "uuid" },
    "revision": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
    "language": { "enum": ["he", "en", "mixed"] },
    "origin_text": { "type": ["string", "null"] },
    "destination_mode": { "enum": ["fixed", "anywhere", "flexible", "unknown"] },
    "destinations": { "type": "array", "items": { "type": "string" } },
    "date_text": { "type": ["string", "null"] },
    "date_flexibility": { "enum": ["exact", "flexible", "unknown"] },
    "travelers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adults", "children", "child_ages", "rooms"],
      "properties": {
        "adults": { "type": ["integer", "null"], "minimum": 0, "maximum": 20 },
        "children": { "type": ["integer", "null"], "minimum": 0, "maximum": 20 },
        "child_ages": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 17 } },
        "rooms": { "type": ["integer", "null"], "minimum": 1, "maximum": 20 }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency", "flexibility"],
      "properties": {
        "amount": { "type": ["number", "null"], "minimum": 0 },
        "currency": { "enum": ["ILS", "USD", "EUR", "UNKNOWN"] },
        "flexibility": { "enum": ["hard", "soft", "unknown"] }
      }
    },
    "vibes": { "type": "array", "items": { "type": "string" } },
    "hard_constraints": { "type": "array", "items": { "type": "string" } },
    "preferences": { "type": "array", "items": { "type": "string" } },
    "search_scope": { "type": "array", "items": { "enum": ["flights", "accommodation", "transfers", "activities", "dining", "insurance", "connectivity", "equipment"] } },
    "material_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "field", "question", "reason", "blocking", "status"],
        "properties": {
          "id": { "type": "string" },
          "field": { "type": "string" },
          "question": { "type": "string" },
          "reason": { "type": "string" },
          "blocking": { "type": "boolean" },
          "status": { "enum": ["open", "answered", "deferred"] }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel", "input_kind", "input_sha256", "transcript_confirmed"],
      "properties": {
        "channel": { "enum": ["web", "app"] },
        "input_kind": { "enum": ["typed", "voice"] },
        "input_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "transcript_confirmed": { "type": "boolean" }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "blockers"],
      "properties": {
        "status": { "enum": ["needs_clarification", "ready_for_search", "unsupported"] },
        "blockers": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

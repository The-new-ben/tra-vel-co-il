{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/agent/run-event-1.0.0.json",
  "title": "Tra-Vel RunEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "event_id", "sequence", "occurred_at", "type", "phase", "status", "source", "visible", "message", "data"],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "event_id": { "type": "string", "format": "uuid" },
    "sequence": { "type": "integer", "minimum": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "type": { "type": "string", "pattern": "^[a-z]+(?:[._][a-z]+)+$" },
    "phase": { "enum": ["intake", "understanding", "clarification", "supplier_search", "proposal", "approval", "execution", "recovery"] },
    "status": { "enum": ["running", "completed", "waiting", "failed", "cancelled"] },
    "source": { "enum": ["system", "model", "tool", "supplier", "calculation", "human"] },
    "visible": { "type": "boolean" },
    "message": { "type": "string", "minLength": 1 },
    "data": { "type": "object" }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/traveler-role-manifest-v1.schema.json",
  "title": "Tra-Vel trip-scoped role and authority manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "manifest_ref", "trip_ref", "version", "principals", "created_at", "data_boundary"],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "manifest_ref": { "$ref": "#/definitions/manifestRef" },
    "trip_ref": { "$ref": "#/definitions/tripRef" },
    "version": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "principals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["principal_ref", "roles", "traveler_refs", "authority_scopes", "authority_source", "authority_evidence_digest", "valid_from", "valid_until"],
        "properties": {
          "principal_ref": { "$ref": "#/definitions/principalRef" },
          "roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["account_holder", "traveler", "booker", "payer", "guardian", "beneficiary", "emergency_contact", "operator_delegate", "supplier_passenger"] }
          },
          "traveler_refs": {
            "type": "array",
            "maxItems": 100,
            "uniqueItems": true,
            "items": { "$ref": "#/definitions/travelerRef" }
          },
          "authority_scopes": {
            "type": "array",
            "uniqueItems": true,
            "items": { "$ref": "#/definitions/authorityScope" }
          },
          "authority_source": { "enum": ["self", "documented_consent", "guardian_evidence", "organization_policy", "supplier_acceptance", "operator_assignment"] },
          "authority_evidence_digest": { "$ref": "#/definitions/nullableDigest" },
          "valid_from": { "$ref": "#/definitions/dateTime" },
          "valid_until": { "$ref": "#/definitions/dateTime" }
        }
      }
    },
    "created_at": { "$ref": "#/definitions/dateTime" },
    "data_boundary": { "$ref": "#/definitions/dataBoundary" }
  },
  "definitions": {
    "manifestRef": { "type": "string", "pattern": "^tv_manifest_[A-Za-z0-9_-]{16,96}$" },
    "tripRef": { "type": "string", "pattern": "^tv_trip_[A-Za-z0-9_-]{16,96}$" },
    "principalRef": { "type": "string", "pattern": "^tv_principal_[A-Za-z0-9_-]{16,96}$" },
    "travelerRef": { "type": "string", "pattern": "^tv_traveler_[A-Za-z0-9_-]{16,96}$" },
    "authorityScope": { "enum": ["trip_view_redacted", "incident_report", "ordinary_evidence_add", "safe_contact_update", "case_progress_view", "operator_contact_approve", "decision_view", "service_reserve", "service_change", "service_cancel", "payment_authorize", "refund_destination_change", "identity_change", "guardian_authority_change", "sensitive_evidence_disclose", "recovery_channel_change", "delegate_manage"] },
    "nullableDigest": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "dateTime": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "dataBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_identity_data_exposed", "raw_payment_data_exposed", "raw_medical_data_exposed", "raw_provider_payload_exposed", "bearer_secret_exposed"],
      "properties": {
        "raw_identity_data_exposed": { "const": false },
        "raw_payment_data_exposed": { "const": false },
        "raw_medical_data_exposed": { "const": false },
        "raw_provider_payload_exposed": { "const": false },
        "bearer_secret_exposed": { "const": false }
      }
    }
  }
}

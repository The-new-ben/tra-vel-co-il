{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/commerce-search-request-v1.schema.json",
  "title": "Tra-Vel canonical commerce sandbox search request",
  "description": "A bounded structured request after language interpretation. It contains no prompt, contact, payment, medical, or supplier reference data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "environment",
    "request_ref",
    "request_digest",
    "verticals",
    "trip",
    "preferences",
    "ranking",
    "sandbox_truth",
    "data_boundary"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "environment": { "const": "sandbox" },
    "request_ref": { "$ref": "#/definitions/requestRef" },
    "request_digest": { "$ref": "#/definitions/digest" },
    "verticals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 9,
      "uniqueItems": true,
      "items": { "$ref": "#/definitions/vertical" }
    },
    "trip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "destination_mode",
        "destinations",
        "date_window",
        "travelers",
        "currency",
        "budget_limit_minor"
      ],
      "properties": {
        "origin": { "$ref": "#/definitions/placeQuery" },
        "destination_mode": { "enum": ["fixed", "flexible", "anywhere"] },
        "destinations": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/definitions/placeQuery" }
        },
        "date_window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "departure_earliest",
            "departure_latest",
            "return_earliest",
            "return_latest",
            "nights_min",
            "nights_max"
          ],
          "properties": {
            "departure_earliest": { "$ref": "#/definitions/nullableDate" },
            "departure_latest": { "$ref": "#/definitions/nullableDate" },
            "return_earliest": { "$ref": "#/definitions/nullableDate" },
            "return_latest": { "$ref": "#/definitions/nullableDate" },
            "nights_min": { "type": "integer", "minimum": 0, "maximum": 365 },
            "nights_max": { "type": "integer", "minimum": 0, "maximum": 365 }
          }
        },
        "travelers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["adults", "children", "infants", "rooms"],
          "properties": {
            "adults": { "type": "integer", "minimum": 1, "maximum": 20 },
            "children": { "type": "integer", "minimum": 0, "maximum": 20 },
            "infants": { "type": "integer", "minimum": 0, "maximum": 10 },
            "rooms": { "type": "integer", "minimum": 1, "maximum": 10 }
          }
        },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "budget_limit_minor": { "type": ["integer", "null"], "minimum": 0, "maximum": 1000000000000 }
      }
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct_only", "max_stops", "priorities", "vibes", "accessibility_requested"],
      "properties": {
        "direct_only": { "type": "boolean" },
        "max_stops": { "type": "integer", "minimum": 0, "maximum": 3 },
        "priorities": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": ["price", "duration", "comfort", "flexibility", "location", "simplicity", "family", "accessibility"]
          }
        },
        "vibes": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": ["city", "beach", "nature", "romantic", "family", "adventure", "food", "wellness", "nightlife", "surprise"]
          }
        },
        "accessibility_requested": { "type": "boolean" }
      }
    },
    "ranking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "ranking_version", "selection_seed_digest"],
      "properties": {
        "profile": { "enum": ["value", "fastest", "flexible", "family", "surprise"] },
        "ranking_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "selection_seed_digest": { "$ref": "#/definitions/digest" }
      }
    },
    "sandbox_truth": { "$ref": "#/definitions/sandboxTruth" },
    "data_boundary": { "$ref": "#/definitions/dataBoundary" }
  },
  "definitions": {
    "vertical": {
      "enum": [
        "flight",
        "accommodation",
        "package",
        "transfer",
        "activity",
        "dining",
        "insurance",
        "connectivity",
        "equipment"
      ]
    },
    "requestRef": {
      "type": "string",
      "pattern": "^tv_request_[A-Za-z0-9_-]{16,96}$",
      "maxLength": 120
    },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nullableDate": {
      "type": ["string", "null"],
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "placeQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "code", "label", "latitude", "longitude"],
      "properties": {
        "kind": { "enum": ["iata", "place", "geo", "open"] },
        "code": {
          "type": ["string", "null"],
          "pattern": "^[A-Z0-9-]{2,12}$"
        },
        "label": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 }
      }
    },
    "sandboxTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "simulated_inventory",
        "real_supplier_request",
        "real_inventory_hold",
        "real_charge",
        "real_booking",
        "real_policy_issuance",
        "real_settlement"
      ],
      "properties": {
        "simulated_inventory": { "const": true },
        "real_supplier_request": { "const": false },
        "real_inventory_hold": { "const": false },
        "real_charge": { "const": false },
        "real_booking": { "const": false },
        "real_policy_issuance": { "const": false },
        "real_settlement": { "const": false }
      }
    },
    "dataBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_supplier_reference_exposed", "raw_payment_data_exposed", "medical_data_exposed"],
      "properties": {
        "raw_supplier_reference_exposed": { "const": false },
        "raw_payment_data_exposed": { "const": false },
        "medical_data_exposed": { "const": false }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tra-vel.co.il/wp-json/tra-vel-agent/v1/schema/commercial-intent#1.0.0",
  "title": "Tra-Vel Commercial Intent",
  "description": "A private, durable and non-binding record of a traveler's request to verify a travel option. It is not an order, reservation, booking, ticket, policy or payment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "intent_id",
    "reference",
    "status",
    "version",
    "ownership",
    "vertical",
    "scope",
    "created_at",
    "updated_at",
    "expires_at"
  ],
  "properties": {
    "contract_version": {"const": "1.0.0"},
    "intent_id": {"type": "string", "format": "uuid"},
    "reference": {"type": "string", "pattern": "^TVI-[A-Z0-9]{8}$"},
    "status": {"enum": ["active", "expired"]},
    "version": {"type": "integer", "minimum": 1},
    "ownership": {"enum": ["account", "private_browser_owner"]},
    "vertical": {"enum": ["flight", "hotel", "package", "insurance", "car", "transfer", "activity", "esim"]},
    "scope": {"$ref": "#/$defs/scope"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_version", "vertical", "surface", "data_mode", "requested_provider", "resolved_provider", "offer_id", "trip", "candidate", "commercial_boundary"],
      "properties": {
        "contract_version": {"const": "1.0.0"},
        "vertical": {"enum": ["flight", "hotel", "package", "insurance", "car", "transfer", "activity", "esim"]},
        "surface": {"type": "string", "minLength": 1, "maxLength": 32},
        "data_mode": {"enum": ["demo", "mixed", "live"]},
        "requested_provider": {"type": "string", "pattern": "^[a-z0-9_-]{2,40}$"},
        "resolved_provider": {"const": "tra-vel-concierge"},
        "offer_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,80}$"},
        "trip": {"$ref": "#/$defs/trip"},
        "candidate": {"$ref": "#/$defs/candidate"},
        "commercial_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "price_status"],
          "properties": {
            "state": {"const": "non_binding_planning_intent"},
            "price_status": {"const": "final_price_and_availability_require_personal_quote"}
          }
        }
      }
    },
    "trip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "destination", "depart_date", "return_date", "adults", "children", "infants", "travelers", "rooms", "budget", "currency", "return_path"],
      "properties": {
        "origin": {"type": "string", "maxLength": 80},
        "destination": {"type": "string", "maxLength": 80},
        "depart_date": {"type": "string", "pattern": "^(?:[0-9]{4}-[0-9]{2}-[0-9]{2})?$"},
        "return_date": {"type": "string", "pattern": "^(?:[0-9]{4}-[0-9]{2}-[0-9]{2})?$"},
        "adults": {"type": "integer", "minimum": 0, "maximum": 20},
        "children": {"type": "integer", "minimum": 0, "maximum": 20},
        "infants": {"type": "integer", "minimum": 0, "maximum": 10},
        "travelers": {"type": "integer", "minimum": 1, "maximum": 20},
        "rooms": {"type": "integer", "minimum": 1, "maximum": 10},
        "budget": {"type": "integer", "minimum": 0, "maximum": 1000000},
        "currency": {"enum": ["ILS", "USD", "EUR", "GBP"]},
        "return_path": {"type": "string", "minLength": 1, "maxLength": 200, "pattern": "^/"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "subtitle", "commercial_ref", "price_scope"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,80}$"},
        "title": {"type": "string", "maxLength": 120},
        "subtitle": {"type": "string", "maxLength": 180},
        "commercial_ref": {"type": "string", "maxLength": 100, "pattern": "^(?:[A-Za-z0-9._:-]{1,100})?$"},
        "price_scope": {"type": "string", "minLength": 1, "maxLength": 40}
      }
    }
  }
}

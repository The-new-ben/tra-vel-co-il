{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/credential-product-v1.schema.json",
  "title": "Tra-Vel credential product catalogue record",
  "description": "An exact issuer and payment-network product identity. It deliberately contains no cardholder credential or authentication material.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "credential_product_id",
    "issuer_id",
    "network_id",
    "product_code",
    "display_name",
    "tier",
    "residency_scopes",
    "effective_window",
    "status",
    "integration_state",
    "source",
    "commercial_truth"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "credential_product_id": { "type": "string", "pattern": "^credential_[a-z0-9][a-z0-9_]{2,51}$", "maxLength": 64 },
    "issuer_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64 },
    "network_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$", "maxLength": 64 },
    "product_code": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,63}$", "maxLength": 64 },
    "display_name": { "type": "string", "minLength": 2, "maxLength": 100 },
    "tier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,31}$", "maxLength": 32 },
    "residency_scopes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(?:[A-Z]{2}|global)$" }
    },
    "effective_window": { "$ref": "#/definitions/window" },
    "status": { "enum": ["catalogued", "active", "transition", "suspended", "retired", "unverified"] },
    "integration_state": { "$ref": "#/definitions/integration_state" },
    "source": { "$ref": "#/definitions/source" },
    "commercial_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["live_eligibility_verification"],
      "properties": { "live_eligibility_verification": { "const": false } }
    }
  },
  "definitions": {
    "integration_state": {
      "enum": ["not_configured", "source_catalogued", "manual_planning_only", "announced_not_operational", "provider_authorization_required"]
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_utc", "to_utc"],
      "properties": {
        "from_utc": { "type": ["string", "null"], "format": "date-time" },
        "to_utc": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "official_source_url", "source_content_digest", "observed_at_utc", "fresh_until_utc", "locale", "review_state"],
      "properties": {
        "authority": { "enum": ["signed_partner_api", "provider_authorized_api", "official_rules", "official_product_page", "provider_support_confirmation", "customer_evidence", "customer_assertion"] },
        "official_source_url": { "type": ["string", "null"], "pattern": "^https://", "maxLength": 2048 },
        "source_content_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "observed_at_utc": { "type": "string", "format": "date-time" },
        "fresh_until_utc": { "type": "string", "format": "date-time" },
        "locale": { "type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$" },
        "review_state": { "enum": ["unreviewed", "reviewed", "quarantined", "superseded"] }
      }
    }
  }
}

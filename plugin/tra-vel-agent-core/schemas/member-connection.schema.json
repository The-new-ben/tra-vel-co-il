{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tra-vel.co.il/schemas/member-connection-v1.schema.json",
  "title": "Tra-Vel member benefit connection",
  "description": "A revocable, least-privilege benefit connection record. Authentication material and payment credentials are outside this contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "connection_id",
    "user_reference_digest",
    "program_id",
    "mode",
    "state",
    "subject_reference_digest",
    "assurance",
    "consent",
    "freshness",
    "commercial_truth"
  ],
  "properties": {
    "contract_version": { "const": "1.0.0" },
    "connection_id": { "type": "string", "pattern": "^connection_[a-z0-9][a-z0-9_]{2,51}$", "maxLength": 64 },
    "user_reference_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "program_id": { "type": "string", "pattern": "^program_[a-z0-9][a-z0-9_]{2,55}$", "maxLength": 64 },
    "mode": { "enum": ["provider_oauth", "licensed_open_finance", "provider_deep_link", "manual_balance", "statement_evidence"] },
    "state": { "enum": ["not_connected", "authorization_started", "connected_read_only", "refresh_required", "connected_current", "redemption_step_up_required", "redemption_authorized", "disconnected"] },
    "subject_reference_digest": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "assurance": { "enum": ["provider_verified", "authorized_partner_verified", "official_terms_verified", "customer_evidence", "customer_asserted", "unknown"] },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consent_version", "consent_reference_digest", "purpose", "scopes", "issued_at_utc", "expires_at_utc", "retention_until_utc", "refresh_permission", "redemption_permission", "revocation_route_id"],
      "properties": {
        "consent_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$", "maxLength": 24 },
        "consent_reference_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "purpose": { "enum": ["planning", "balance_comparison", "benefit_redemption"] },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "enum": ["read_balance", "refresh_balance", "redeem", "disconnect"] }
        },
        "issued_at_utc": { "type": "string", "format": "date-time" },
        "expires_at_utc": { "type": "string", "format": "date-time" },
        "retention_until_utc": { "type": "string", "format": "date-time" },
        "refresh_permission": { "type": "boolean" },
        "redemption_permission": { "type": "boolean" },
        "revocation_route_id": { "type": "string", "pattern": "^revocation_[a-z0-9][a-z0-9_]{2,51}$", "maxLength": 64 }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at_utc", "fresh_until_utc"],
      "properties": {
        "observed_at_utc": { "type": ["string", "null"], "format": "date-time" },
        "fresh_until_utc": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "commercial_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_connection_live", "redemption_enabled"],
      "properties": {
        "provider_connection_live": { "const": false },
        "redemption_enabled": { "const": false }
      }
    }
  }
}
